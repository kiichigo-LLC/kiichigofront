{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "assets:scss": "sass public/scss/style.scss public/css/style.css --style=compressed --source-map",
    "assets:scss:watch": "sass --watch public/scss/style.scss:public/css/style.css --style=compressed --source-map",
    "assets:build": "npm run assets:scss",
    "assets:watch": "npm run assets:scss:watch",
    "dev": "npm run assets:build && concurrently -k \"next dev -p 1234\" \"npm run assets:watch\"",
    "build": "npm run assets:build && next build",
    "build:prod": "([ -f .env.local ] && mv .env.local .env.local.bak || true) && npm run assets:build && next build; s=$?; ([ -f .env.local.bak ] && mv .env.local.bak .env.local || true); exit $s",
    "start": "npx serve@latest out -l 1235",
    "lint": "eslint"
  },
  "dependencies": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "next": "15.5.18"
  },
  "devDependencies": {
    "typescript": "^5",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.18",
    "@eslint/eslintrc": "^3",
    "chokidar-cli": "3.0.0",
    "concurrently": "9.2.1",
    "sass": "1.77.8",
    "terser": "5.44.1"
  }
}
