# WordPress 本体（Docker のポートに合わせる）
WP_SITE_URL=http://localhost:18080
WP_API_URL=http://localhost:18080/wp-json/wp/v2
KIICHIGO_API_URL=http://localhost:18080/wp-json/kiichigo/v1

# ローカル DB に uploads / attachment が無いとき、本番からアイキャッチ URL を借りる
WP_MEDIA_FALLBACK_URL=https://kiichigo.work

# テーマ URI（未設定時は WP_SITE_URL + /wp-content/themes/main）
# NEXT_PUBLIC_WP_THEME_URL=http://localhost:18080/wp-content/themes/main

# Next 側の URL
NEXT_PUBLIC_SITE_URL=http://localhost:1234
