{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [
      {
        "source": "/wp-media-proxy/:path*",
        "destination": "https://wp.kiichigo.work/wp-json/wp/v2/:path*",
        "regex": "^/wp-media-proxy(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
      },
      {
        "source": "/koe/:slug",
        "destination": "/koe/entry",
        "regex": "^/koe(?:/([^/]+?))(?:/)?$"
      },
      {
        "source": "/web/:slug",
        "destination": "/web/entry",
        "regex": "^/web(?:/([^/]+?))(?:/)?$"
      },
      {
        "source": "/trajectory/:slug",
        "destination": "/trajectory/entry",
        "regex": "^/trajectory(?:/([^/]+?))(?:/)?$"
      },
      {
        "source": "/tag/:slug/page/:page",
        "destination": "/tag/entry",
        "regex": "^/tag(?:/([^/]+?))/page(?:/([^/]+?))(?:/)?$"
      },
      {
        "source": "/tag/:slug",
        "destination": "/tag/entry",
        "regex": "^/tag(?:/([^/]+?))(?:/)?$"
      }
    ],
    "fallback": []
  },
  "dynamicRoutes": [],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/about",
      "regex": "^/about(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/about(?:/)?$"
    },
    {
      "page": "/contact",
      "regex": "^/contact(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/contact(?:/)?$"
    },
    {
      "page": "/contact/error",
      "regex": "^/contact/error(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/contact/error(?:/)?$"
    },
    {
      "page": "/contact/thanks",
      "regex": "^/contact/thanks(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/contact/thanks(?:/)?$"
    },
    {
      "page": "/dx",
      "regex": "^/dx(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dx(?:/)?$"
    },
    {
      "page": "/koe",
      "regex": "^/koe(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/koe(?:/)?$"
    },
    {
      "page": "/koe/entry",
      "regex": "^/koe/entry(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/koe/entry(?:/)?$"
    },
    {
      "page": "/portfolio",
      "regex": "^/portfolio(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/portfolio(?:/)?$"
    },
    {
      "page": "/portfolio/dtp",
      "regex": "^/portfolio/dtp(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/portfolio/dtp(?:/)?$"
    },
    {
      "page": "/tag",
      "regex": "^/tag(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/tag(?:/)?$"
    },
    {
      "page": "/tag/entry",
      "regex": "^/tag/entry(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/tag/entry(?:/)?$"
    },
    {
      "page": "/trajectory",
      "regex": "^/trajectory(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/trajectory(?:/)?$"
    },
    {
      "page": "/trajectory/entry",
      "regex": "^/trajectory/entry(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/trajectory/entry(?:/)?$"
    },
    {
      "page": "/web",
      "regex": "^/web(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/web(?:/)?$"
    },
    {
      "page": "/web/entry",
      "regex": "^/web/entry(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/web/entry(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}